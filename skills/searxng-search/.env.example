# SearXNG Search Configuration
# Copy this file to .env and customize as needed

# SearXNG instance URL (default: local Docker instance)
SEARXNG_URL=http://localhost:8888

# Request timeout in seconds
SEARXNG_TIMEOUT=10

# Default language (auto-detect or use language codes like en, zh, de)
# SEARXNG_LANGUAGE=auto

# Default safe search level (0=None, 1=Moderate, 2=Strict)
# SEARXNG_SAFESEARCH=0
